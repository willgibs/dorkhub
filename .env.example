# Supabase (client-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase (server only — never expose)
SUPABASE_SECRET_KEY=

# GitHub server PAT: fine-grained, "Public repositories (read-only)", zero account permissions.
# Used for ALL GitHub reads (repo lists, metadata, READMEs). We deliberately do not use
# per-user provider tokens — see plan Part 2 §GitHub.
GITHUB_TOKEN=

# Shared secret guarding /api/cron/* endpoints
CRON_SECRET=
